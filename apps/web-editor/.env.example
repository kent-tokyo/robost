# ── AI Chat Assistant ─────────────────────────────────────────────────────────
# Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by the AI assistant
# ROBOST_AI_MODEL=claude-sonnet-4-6

# ── Agent server ──────────────────────────────────────────────────────────────
# Port the agent listens on (default: 9921)
# ROBOST_PORT=9921

# Scenarios directory (default: ~/Documents/robost/scenarios)
# ROBOST_SCENARIOS_DIR=C:\Users\YourName\Documents\robost\scenarios
